{
    "name": "wenpai/wpmind",
    "description": "WPMind - WordPress AI 自定义端点扩展",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "yoast/wp-test-utils": "^1.2"
    },
    "autoload": {
        "psr-4": {
            "WPMind\\": "includes/"
        }
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
