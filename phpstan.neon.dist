includes:
    - %rootDir%/../../szepeviktor/phpstan-wordpress/extension.neon

parameters:
    level: 3
    paths:
        - includes
        - modules
        - wpmind.php
        - uninstall.php
    excludePaths:
        analyseAndScan:
            - vendor (?)
            - tests (?)
            - node_modules (?)
    # 忽略的错误模式（level 3 暂无需忽略，升级 level 时按需添加）
    ignoreErrors: []
    checkUninitializedProperties: true
    checkMissingCallableSignature: true
